import java.util.HashMap;
import java.util.Map;
import java.util.Scanner;

class Product {
    String name;
    int quantity;
    double price;

    public Product(String name, int quantity, double price) {
        this.name = name;
        this.quantity = quantity;
        this.price = price;
    }

    public void display() {
        System.out.println("Атауы: " + name + ", Саны: " + quantity + ", Бағасы: " + price);
    }
}

public class WarehouseSystem {
    static Map<String, Product> products = new HashMap<>();

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        while (true) {
            System.out.println("\n1. Қосу");
            System.out.println("2. Көру");
            System.out.println("3. Жаңарту");
            System.out.println("4. Жою");
            System.out.println("5. Іздеу");
            System.out.println("0. Шығу");

            int choice = sc.nextInt();
            sc.nextLine();

            switch (choice) {
                case 1:
                    addProduct(sc);
                    break;
                case 2:
                    showProducts();
                    break;
                case 3:
                    updateProduct(sc);
                    break;
                case 4:
                    deleteProduct(sc);
                    break;
                case 5:
                    searchProduct(sc);
                    break;
                case 0:
                    return;
            }
        }
    }

    static void addProduct(Scanner sc) {
        System.out.print("Атауын енгіз: ");
        String name = sc.nextLine();

        System.out.print("Санын енгіз: ");
        int quantity = sc.nextInt();

        System.out.print("Бағасын енгіз: ");
        double price = sc.nextDouble();

        products.put(name, new Product(name, quantity, price));
        System.out.println("Тауар қосылды!");
    }

    static void showProducts() {
        for (Product p : products.values()) {
            p.display();
        }
    }

    static void updateProduct(Scanner sc) {
        System.out.print("Жаңартатын тауар атауы: ");
        String name = sc.nextLine();

        if (products.containsKey(name)) {
            System.out.print("Жаңа саны: ");
            int quantity = sc.nextInt();

            System.out.print("Жаңа баға: ");
            double price = sc.nextDouble();

            products.put(name, new Product(name, quantity, price));
            System.out.println("Жаңартылды!");
        } else {
            System.out.println("Тауар табылмады!");
        }
    }

    static void deleteProduct(Scanner sc) {
        System.out.print("Жоятын тауар атауы: ");
        String name = sc.nextLine();

        products.remove(name);
        System.out.println("Жойылды!");
    }

    static void searchProduct(Scanner sc) {
        System.out.print("Іздеу: ");
        String name = sc.nextLine();

        if (products.containsKey(name)) {
            products.get(name).display();
        } else {
            System.out.println("Тауар табылмады!");
        }
    }
}
